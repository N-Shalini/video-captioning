import os
import json
import glob
import re
import torch
import torch.nn as nn
from tqdm import tqdm
from dataset import get_dataloader
from model import VideoCaptionModel
from config import Config

def train_model():
    print("Loading vocab...")
    with open('data/vocab.json', 'r') as f:
        vocab = json.load(f)
    vocab_size = len(vocab)
    
    print(f"Vocab size: {vocab_size}")
    train_dataloader = get_dataloader(vocab_path='data/vocab.json', split='train')
    val_dataloader = get_dataloader(vocab_path='data/vocab.json', split='val', shuffle=False)
    
    device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
    
    model = VideoCaptionModel(vocab_size, Config.FEATURE_DIM, Config.EMBED_DIM, Config.HIDDEN_DIM)
    
    start_epoch = 0
    history_path = os.path.join(Config.MODELS_DIR, "loss_history.json")

    # Check for existing checkpoints to resume training
    checkpoints = glob.glob(os.path.join(Config.MODELS_DIR, "attention_model_ep*.pth"))
    if checkpoints:
        epochs = []
        for cp in checkpoints:
            match = re.search(r'ep(\d+)\.pth', cp)
            if match:
                epochs.append(int(match.group(1)))
        if epochs:
            start_epoch = max(epochs)
            latest_checkpoint = os.path.join(Config.MODELS_DIR, f"attention_model_ep{start_epoch}.pth")
            print(f"Resuming training from epoch {start_epoch} (checkpoint: {latest_checkpoint})...")
            model.load_state_dict(torch.load(latest_checkpoint, map_location='cpu'))

    model.to(device)
    
    # Ignore <pad>
    pad_idx = vocab[Config.PAD_TOKEN]
    criterion = nn.CrossEntropyLoss(ignore_index=pad_idx)
    optimizer = torch.optim.Adam(model.parameters(), lr=Config.LEARNING_RATE, weight_decay=1e-4)
    scaler = torch.amp.GradScaler('cuda')  # AMP scaler for mixed precision
    # Halve LR if val loss doesn't improve for 2 epochs
    scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode='min', factor=0.5, patience=2)
    
    # Early stopping
    best_val_loss = float('inf')
    patience_counter = 0
    EARLY_STOP_PATIENCE = 3
    best_model_path = os.path.join(Config.MODELS_DIR, "best_model.pth")
    
    print(f"Starting training on device: {device}")
    
    if start_epoch > 0 and os.path.exists(history_path):
        with open(history_path, 'r') as f:
            history = json.load(f)
    else:
        history = {'train_loss': [], 'val_loss': []}
        
    for epoch in range(start_epoch, Config.EPOCHS):
        model.train()
        total_loss = 0.0
        
        # tqdm for batch info
        progress_bar = tqdm(train_dataloader, desc=f"Epoch {epoch+1}/{Config.EPOCHS} [Train]")
        for i, (features, captions) in enumerate(progress_bar):
            features = features.to(device)
            captions = captions.to(device)
            
            # Use teacher forcing: input is captions[:, :-1], target is captions[:, 1:]
            input_caps = captions[:, :-1]
            target_caps = captions[:, 1:]
            
            optimizer.zero_grad()
            
            with torch.amp.autocast('cuda'):  # AMP: use FP16 where safe
                outputs = model(features, input_caps) # [batch_size, max_length-1, vocab_size]
                
                # Flatten outputs and targets
                outputs = outputs.reshape(-1, vocab_size)
                targets = target_caps.reshape(-1)
                
                loss = criterion(outputs, targets)
            
            scaler.scale(loss).backward()
            scaler.step(optimizer)
            scaler.update()
            
            total_loss += loss.item()
            progress_bar.set_postfix({'loss': f"{loss.item():.4f}"})
            
        avg_train_loss = total_loss / len(train_dataloader)
        
        # Validation Pass
        model.eval()
        val_loss = 0.0
        with torch.no_grad():
            val_bar = tqdm(val_dataloader, desc=f"Epoch {epoch+1}/{Config.EPOCHS} [Val]")
            for i, (features, captions) in enumerate(val_bar):
                features = features.to(device)
                captions = captions.to(device)
                
                input_caps = captions[:, :-1]
                target_caps = captions[:, 1:]
                
                outputs = model(features, input_caps)
                outputs = outputs.reshape(-1, vocab_size)
                targets = target_caps.reshape(-1)
                
                v_loss = criterion(outputs, targets)
                val_loss += v_loss.item()
                val_bar.set_postfix({'val_loss': f"{v_loss.item():.4f}"})
                
        avg_val_loss = val_loss / len(val_dataloader)
        print(f"Epoch [{epoch+1}/{Config.EPOCHS}], Train Loss: {avg_train_loss:.4f}, Val Loss: {avg_val_loss:.4f}")
        
        # Step LR scheduler based on val loss
        scheduler.step(avg_val_loss)
        
        # Save loss history
        history['train_loss'].append(avg_train_loss)
        history['val_loss'].append(avg_val_loss)
        with open(history_path, 'w') as f:
            json.dump(history, f)
        
        # Save latest epoch checkpoint
        current_checkpoint = os.path.join(Config.MODELS_DIR, f"attention_model_ep{epoch+1}.pth")
        torch.save(model.state_dict(), current_checkpoint)
        
        # Save best model separately
        if avg_val_loss < best_val_loss:
            best_val_loss = avg_val_loss
            patience_counter = 0
            torch.save(model.state_dict(), best_model_path)
            print(f"  --> New best model saved (val_loss={best_val_loss:.4f})")
        else:
            patience_counter += 1
            print(f"  --> No improvement. Patience: {patience_counter}/{EARLY_STOP_PATIENCE}")
            if patience_counter >= EARLY_STOP_PATIENCE:
                print(f"Early stopping triggered. Best val loss: {best_val_loss:.4f}")
                break
        
        # All epoch checkpoints are kept (attention_model_ep1.pth ... ep10.pth)
        
    print("Training finished.")

if __name__ == '__main__':
    train_model()
